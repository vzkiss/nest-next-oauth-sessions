# API
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/xborg"
SESSION_SECRET="a-string-secret-at-least-256-bits-long"

# Public base URL of this API (no trailing slash). OAuth callback defaults to API_ORIGIN/auth/validate/google
API_ORIGIN="http://localhost:3000"

# OAuth client (redirect URI in Google Console must match google.callbackUrl)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# Optional: full callback URL if not using API_ORIGIN + default path
# GOOGLE_CALLBACK_URL="https://api.example.com/auth/validate/google"

# Public origin of the Next.js app (scheme + host + port, no trailing slash).
# Used for: CORS allowlist, OAuth success redirect to /auth/callback.
# Local dev example matches `pnpm dev` default for the web app.
CLIENT_ORIGIN="http://localhost:4000"

# Web (NEXT_PUBLIC_* is exposed to the browser)
NEXT_PUBLIC_API_URL="http://localhost:3000"
# NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# Docker (local Postgres)
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="xborg"
